}

@ cases.append-and-edit-tail
input_eure = ```eure
// first user
users[] {
  name = "Alice"
}
```

edited = ```eure
// first user
users[] {
  name = "Alice"
}
users[] {
  name = "Bob"
  age = 30
}
```

@ cases.append-and-edit-tail.edit_commands[] {
  $variant = "Set"
  path = "users[].name"
  value = eure`"Bob"`
}

@ cases.append-and-edit-tail.edit_commands[] {
  $variant = "Set"
  path = "users[^].age"
  value = eure`30`
}

