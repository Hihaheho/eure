@ cases.nested-array-append
input_eure = ```eure
orgs[] {
  name = "Acme"
  teams[] {
    name = "Core"
  }
}
```

edited = ```eure
orgs[] {
  name = "Acme"
  teams[] {
    name = "Core"
  }
  teams[] {
    name = "Platform"
    members = ["Ada"]
  }
}
```

@ cases.nested-array-append.edit_commands[] {
  $variant = "Set"
  path = "orgs[^].teams[].name"
  value = eure`"Platform"`
}

@ cases.nested-array-append.edit_commands[] {
  $variant = "Set"
  path = "orgs[^].teams[^].members[]"
  value = eure`"Ada"`
}

@ cases.nested-array-insert-preserves-shifted-comment
input_eure = ```eure
orgs[] {
  name = "Acme"
  teams[] {
    name = "Core"
  }
  // existing second team
  teams[] {
    name = "Infra"
  }
}
```

edited = ```eure
orgs[] {
  name = "Acme"
  teams[] {
    name = "Core"
  }
  teams[] {
    name = "Platform"
    lead = "Ada"
  }
  // existing second team
  teams[] {
    name = "Infra"
  }
}
```

@ cases.nested-array-insert-preserves-shifted-comment.edit_commands[] {
  $variant = "Insert"
  path = "orgs[^].teams[1].name"
  value = eure`"Platform"`
}

@ cases.nested-array-insert-preserves-shifted-comment.edit_commands[] {
  $variant = "Set"
  path = "orgs[^].teams[1].lead"
  value = eure`"Ada"`
}

