@ cases.readme
schema = path`crates/eure-dev/assets/readme.schema.eure`
scenarios_expected = ["rust_codegen"]
rust = ```rust
pub struct RootName {
    pub value: String,
    pub pronunciation: Option<String>,
    pub note: Option<String>,
    pub origin: Option<String>,
    pub github: Option<String>,
    pub version: String,
    pub description: String,
}

pub struct RootStatus {
    pub phase: String,
}

pub struct Root {
    pub name: RootName,
    pub status: Option<RootStatus>,
    pub features: Vec<Feature>,
    pub credits: Option<Vec<Credit>>,
}

#[eure(type_name = "credit")]
pub struct Credit {
    pub name: String,
    pub url: String,
    pub description: String,
}

#[eure(type_name = "feature")]
pub enum Feature {
    #[eure(rename = "done")]
    Done { title: String, icon: String, description: String },
    #[eure(rename = "in-progress")]
    InProgress { title: String, icon: String, description: String, milestone: String },
    #[eure(rename = "planned")]
    Planned { title: String, icon: String, description: String, target: String },
}
```

@ cases.adr
schema = path`assets/schemas/eure-adr.schema.eure`
scenarios_expected = ["rust_codegen"]
rust = ```rust
pub enum RootStatus {
    #[eure(rename = "proposed")]
    Proposed(::eure_document::document::EureDocument),
    #[eure(rename = "accepted")]
    Accepted(::eure_document::document::EureDocument),
    #[eure(rename = "rejected")]
    Rejected { reason: String },
    #[eure(rename = "deprecated")]
    Deprecated { reason: String },
    #[eure(rename = "superseded")]
    Superseded { superseded_by: AdrId },
}

pub struct Root {
    pub id: AdrId,
    pub title: String,
    pub status: RootStatus,
    #[eure(rename = "decision-date")]
    pub decision_date: String,
    pub context: String,
    pub decision: String,
    pub consequences: String,
    #[eure(rename = "related-adrs")]
    pub related_adrs: Option<Vec<AdrId>>,
    #[eure(rename = "related-links")]
    pub related_links: Option<Vec<String>>,
    #[eure(rename = "alternatives-considered")]
    pub alternatives_considered: Option<Vec<String>>,
    pub tags: Option<Vec<String>>,
    pub authors: Option<Vec<String>>,
}

#[eure(type_name = "adr-id")]
pub struct AdrId(pub String);
```

