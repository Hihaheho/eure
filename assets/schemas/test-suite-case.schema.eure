= `$types.case-file`
$types {
  unimplemented-reason {
    $variant = "union"
    variants = { Boolean => `boolean`, Text => `text` }
  }
  completion-item {
    label = `text`
    @ kind
    $variant = "union"
    $optional = true
    variants = { some => `text`, none => `null` }
  }
  diagnostic-item {
    @ severity
    $variant = "union"
    $optional = true
    variants = { some => `text`, none => `null` }
    @ source
    $variant = "union"
    $optional = true
    variants = { some => `text`, none => `null` }
    @ message
    $variant = "union"
    $optional = true
    variants = { some => `text`, none => `null` }
    @ code
    $variant = "union"
    $optional = true
    variants = { some => `text`, none => `null` }
    @ span
    $variant = "union"
    $optional = true
    variants = { some => `text`, none => `null` }
    @ span_index
    $variant = "union"
    $optional = true
    variants = { some => `integer`, none => `null` }
  }
  semantic-token-item {
    $variant = "union"
    variants = { WithModifiers => (`text`, `text`, [`text`]), Plain => (`text`, `text`) }
  }
  scenario-error-item {
    scenario = `text`
    output = `text`
  }
  json-data {
    $variant = "union"
    @ variants
    Both = { json => `text` }
    Separate {
      @ input_json
      $variant = "union"
      $optional = true
      variants = { some => `text`, none => `null` }
      @ output_json
      $variant = "union"
      $optional = true
      variants = { some => `text`, none => `null` }
    }
  }
  json-schema-data {
    $variant = "union"
    @ variants
    Both = { json_schema => `text` }
    Separate {
      @ input_json_schema
      $variant = "union"
      $optional = true
      variants = { some => `text`, none => `null` }
      @ output_json_schema
      $variant = "union"
      $optional = true
      variants = { some => `text`, none => `null` }
    }
  }
  case-data {
    $flatten = [`$types.json-data`, `$types.json-schema-data`]
    schema_errors = [`text`]
    schema_errors.$optional = true
    meta_schema_errors = [`text`]
    meta_schema_errors.$optional = true
    json_schema_errors = [`text`]
    json_schema_errors.$optional = true
    euremark_errors = [`text`]
    euremark_errors.$optional = true
    completions = [`$types.completion-item`]
    completions.$optional = true
    diagnostics = [`$types.diagnostic-item`]
    diagnostics.$optional = true
    json_errors = [`text`]
    json_errors.$optional = true
    semantic_tokens = [`$types.semantic-token-item`]
    semantic_tokens.$optional = true
    scenario_errors = [`$types.scenario-error-item`]
    scenario_errors.$optional = true
    scenarios_expected = [`text`]
    scenarios_expected.$optional = true
    @ input_eure
    $variant = "union"
    $optional = true
    variants = { some => `text`, none => `null` }
    @ input_toml
    $variant = "union"
    $optional = true
    variants = { some => `text`, none => `null` }
    @ normalized
    $variant = "union"
    $optional = true
    variants = { some => `text`, none => `null` }
    @ schema
    $variant = "union"
    $optional = true
    variants = { some => `text`, none => `null` }
    @ schema_conversion_error
    $variant = "union"
    $optional = true
    variants = { some => `text`, none => `null` }
    @ unimplemented
    $variant = "union"
    $optional = true
    variants = { some => `$types.unimplemented-reason`, none => `null` }
    @ formatted_input
    $variant = "union"
    $optional = true
    variants = { some => `text`, none => `null` }
    @ formatted_normalized
    $variant = "union"
    $optional = true
    variants = { some => `text`, none => `null` }
    @ serialized
    $variant = "union"
    $optional = true
    variants = { some => `text`, none => `null` }
    @ editor
    $variant = "union"
    $optional = true
    variants = { some => `text`, none => `null` }
    @ trigger
    $variant = "union"
    $optional = true
    variants = { some => `text`, none => `null` }
  }
  case-file {
    $flatten = [`$types.case-data`]
    @ cases
    $variant = "map"
    $optional = true
    key = `text`
    value = `$types.case-data`
  }
}
