"#": Types

"toc".$toc = true

@ "formatting" {
  "##": Formatting

  "body" = ```markdown
Eure recommends **2-space indentation** for nested structures.
```

  "eure-snippet" = ```eure
@ config {
  server = {
    host = "localhost"
    port = 8080
  }
}
```

}

@ "primitive-types" {
  "##": Primitive Types

  "body" = ```markdown
- `string`
- `typed string`
- `code`
- `integer`
- `float`
- `decimal`
- `boolean`
- `array`
- `object`
- `enum`
- `variant`
- `tuple`
- `unit`
- `null`
```

}

@ "officially-provided-types" {
